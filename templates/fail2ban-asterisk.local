# /etc/fail2ban/jail.d/asterisk.local — STAGED
# Apply only AFTER Asterisk is installed (logpath must exist), then:
#   systemctl enable --now fail2ban && systemctl restart fail2ban
[asterisk]
enabled  = true
filter   = asterisk
action   = iptables-allports[name=ASTERISK, protocol=all]
logpath  = /var/log/asterisk/full
maxretry = 5
findtime = 600
bantime  = 86400
